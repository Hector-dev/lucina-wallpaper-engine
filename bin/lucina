#!/bin/bash
# Lucina Engine v3.2 - Codec Adaptive Edition
# Optimizaciones: Selección manual de HWDEC | Persistencia de Configuración

# --- Configuración de Rutas ---
BASE_DIR="${LUCINA_WALLPAPER_DIR:-$HOME/wallpaper}"
STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
STATE_FILE="$STATE_HOME/lucina_last_wallpaper"
CODEC_FILE="$STATE_HOME/lucina_codec_pref" # Nuevo: guarda tu preferencia
LOG_FILE="$CACHE_HOME/lucina_engine.log"

mkdir -p "$(dirname "$STATE_FILE")" "$(dirname "$LOG_FILE")"

# --- Gestión de Codecs ---
# Si no existe preferencia, intenta detectar; si no, usa auto.
if [ ! -f "$CODEC_FILE" ]; then
    if command -v nvidia-smi &> /dev/null; then echo "nvdec" > "$CODEC_FILE"
    elif lspci | grep -qiE "intel|amd"; then echo "vaapi" > "$CODEC_FILE"
    else echo "auto" > "$CODEC_FILE"; fi
fi
CURRENT_CODEC=$(cat "$CODEC_FILE")

# --- Perfiles de Rendimiento ---
# Eliminamos el flag --hwdec de aquí para inyectarlo dinámicamente
declare -A PROFILES
PROFILES[performance]="--vo=gpu --loop-file=inf --no-audio"
PROFILES[mid]="--vo=gpu --profile=fast --loop-file=inf --no-audio"
PROFILES[low]="--vo=gpu --profile=fast --vd-lavc-fast --framedrop=vo --loop-file=inf --no-audio"
PROFILES[very_low]="--vo=gpu --gpu-context=wayland --hwdec-codecs=all --vd-lavc-fast --framedrop=vo --cache=no --demuxer-max-bytes=1MiB --vd-lavc-threads=1 --sws-scaler=fast --dither=no --scale=nearest --cscale=nearest --loop-file=inf --no-audio --gpu-api=opengl --video-sync=display-desync --alpha=no"

# --- Funciones de Soporte ---
log() { echo "[$(date "+%Y-%m-%d %H:%M:%S")] [$1] $2" >> "$LOG_FILE"; }

change_codec() {
    clear
    echo -e "\e[1;35m--- Configuración de Aceleración de Hardware ---\e[0m"
    echo "Codec actual: $CURRENT_CODEC"
    echo ""
    NEW_CODEC=$(echo -e "vaapi (Recomendado Canaima/Intel)\nnvdec (Recomendado NVIDIA/RTX)\nauto (Detección automática)\nsoftware (Carga total a CPU)" | fzf --prompt="Selecciona Codec: " | awk '{print $1}')
    
    if [ ! -z "$NEW_CODEC" ]; then
        echo "$NEW_CODEC" > "$CODEC_FILE"
        CURRENT_CODEC=$NEW_CODEC
        echo "✅ Preferencia actualizada a: $CURRENT_CODEC"
        sleep 1
    fi
}

start_engine() {
    pkill -SIGTERM mpvpaper 2>/dev/null
    sleep 0.3
    
    MONITOR=$(mpvpaper -d | grep "Output:" | awk '{print $3}' | head -n 1)
    
    # Inyección del codec seleccionado + perfil
    HW_FLAG="--hwdec=$CURRENT_CODEC"
    
    log "INFO" "Iniciando: $1 | Modo: $2 | Codec: $CURRENT_CODEC"
    echo "🚀 Renderizando con $CURRENT_CODEC en modo $2..."
    mpvpaper -f -p -o "$HW_FLAG ${PROFILES[$2]}" "$MONITOR" "$1" >> "$LOG_FILE" 2>&1
}

# --- Menú Principal ---
while true; do
    clear
    echo -e "\e[1;36mLucina Engine v3.2 | Codec: $CURRENT_CODEC | Monitor: $MONITOR\e[0m"
    OPTION=$(echo -e "▶️ Iniciar Wallpaper\n🔄 Restaurar Último\n⚙️  Cambiar Codec (HWDEC)\n🛠️  Optimizar Video\n❌ Salir" | fzf --prompt="Selecciona una acción: ")

    case "$OPTION" in
        "▶️ Iniciar Wallpaper")
            SELECTED=$(find "$BASE_DIR" -maxdepth 2 -type f \( -name "*.mp4" -o -name "*.mkv" \) | sort | fzf --prompt="🌌 Fondo: ")
            [ -z "$SELECTED" ] && continue
            echo "$SELECTED" > "$STATE_FILE"
            
            MODE=$(echo "performance mid low very_low" | tr ' ' '\n' | fzf --prompt="⚡ Perfil: ")
            [ -z "$MODE" ] && continue
            
            start_engine "$SELECTED" "$MODE"
            break
            ;;
        "🔄 Restaurar Último")
            if [ -f "$STATE_FILE" ]; then
                start_engine "$(cat "$STATE_FILE")" "very_low"
                break
            else
                echo "No hay sesión previa."; sleep 2
            fi
            ;;
        "⚙️  Cambiar Codec (HWDEC)")
            change_codec
            ;;
        "🛠️  Optimizar Video")
            # Tu función transform_wallpaper original aquí...
            ;;
        "❌ Salir") exit 0 ;;
        *) exit 0 ;;
    esac
done
