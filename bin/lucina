#!/bin/bash
# Lucina Engine v3.2.1 - Systemd Optimized Edition
# Tech Lead Note: Implementación de 'exec' para persistencia de PID y control de señales.

# --- Configuración de Rutas ---
BASE_DIR="${LUCINA_WALLPAPER_DIR:-$HOME/wallpaper}"
STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
STATE_FILE="$STATE_HOME/lucina_last_wallpaper"
CODEC_FILE="$STATE_HOME/lucina_codec_pref"
PROFILE_FILE="$STATE_HOME/lucina_profile_pref"
LOG_FILE="$CACHE_HOME/lucina_engine.log"
LOCK_FILE="/tmp/lucina.lock"

# --- Detección Dinámica de Wayland (Crucial para Systemd) ---
if [ -z "$WAYLAND_DISPLAY" ]; then
    for i in {0..5}; do
        if [ -S "$XDG_RUNTIME_DIR/wayland-$i" ]; then 
            export WAYLAND_DISPLAY="wayland-$i"
            break
        fi
    done
fi

# Asegurar directorios
mkdir -p "$STATE_HOME" "$CACHE_HOME"
touch "$LOG_FILE"

# --- Gestión de Codecs ---
if [ ! -f "$CODEC_FILE" ]; then
    if command -v nvidia-smi &> /dev/null; then echo "nvdec" > "$CODEC_FILE"
    elif lspci | grep -qiE "intel|amd"; then echo "vaapi" > "$CODEC_FILE"
    else echo "auto" > "$CODEC_FILE"; fi
fi
CURRENT_CODEC=$(cat "$CODEC_FILE")

# --- Perfiles de Rendimiento ---
declare -A PROFILES
PROFILES[performance]="--vo=gpu --loop-file=inf --no-audio"
PROFILES[mid]="--vo=gpu --profile=fast --loop-file=inf --no-audio"
PROFILES[low]="--vo=gpu --profile=fast --vd-lavc-fast --framedrop=vo --loop-file=inf --no-audio"
PROFILES[very_low]="--vo=gpu --gpu-context=wayland --hwdec-codecs=all --vd-lavc-fast --framedrop=vo --cache=no --demuxer-max-bytes=1MiB --vd-lavc-threads=1 --sws-scaler=fast --dither=no --scale=nearest --cscale=nearest --loop-file=inf --no-audio --gpu-api=opengl --video-sync=display-desync --alpha=no --fast --hwdec-extra-frames=0 --gpu-dumb-mode=yes"

# --- Funciones de Soporte ---
log() { echo "[$(date "+%Y-%m-%d %H:%M:%S")] [$1] $2" >> "$LOG_FILE"; }

get_resolution() {
    local res=""
    if command -v hyprctl &>/dev/null; then
        res=$(hyprctl monitors | grep -oP '\d+x\d+@[\d.]+' | head -n 1)
    elif command -v swaymsg &>/dev/null; then
        res=$(swaymsg -t get_outputs | jq -r '.[0].current_mode | "\(.width)x\(.height)"')
    else
        res=$(cat /sys/class/drm/*/modes 2>/dev/null | head -n 1)
    fi
    echo "${res:-Unknown}"
}

start_engine() {
    # Limpieza de cualquier instancia previa para evitar el "ghosting"
    pkill -9 -f mpvpaper 2>/dev/null
    sleep 0.2
    
    MONITOR=$(mpvpaper -d | grep "Output:" | awk '{print $3}' | head -n 1)
    RESOLUTION=$(get_resolution)
    HW_FLAG="--hwdec=$CURRENT_CODEC"
    
    # Manejo de formatos estáticos
    case "${1##*.}" in
        png|jpg|jpeg|webp|gif) HW_FLAG="--hwdec=no" ;;
    esac

    LOOP_FLAGS="--loop-file=inf --loop-playlist=inf --no-audio"
    
    log "INFO" "Renderizando en $MONITOR ($RESOLUTION) con $CURRENT_CODEC en modo $2"
    
    # Persistencia
    echo "$1" > "$STATE_FILE"
    echo "$2" > "$PROFILE_FILE"

    # El EXEC es la clave: el script desaparece y el PID de mpvpaper toma su lugar
    # Esto permite que systemd controle el proceso de forma nativa.
    exec mpvpaper -f -p -o "$HW_FLAG $LOOP_FLAGS ${PROFILES[$2]}" "$MONITOR" "$1" >> "$LOG_FILE" 2>&1
}

# --- Manejo de Argumentos ---
if [[ "$1" == "--restore" ]]; then
    if [ -f "$STATE_FILE" ]; then
        LAST_WALL=$(cat "$STATE_FILE")
        LAST_PROF=$(cat "$PROFILE_FILE" 2>/dev/null || echo "very_low")
        start_engine "$LAST_WALL" "$LAST_PROF"
    else
        log "WARN" "Nada que restaurar."
        exit 0
    fi
fi

# --- Menú Principal (Interactivo) ---
# (Nota: check_instance solo se llama si no es --restore)
[ -f "$LOCK_FILE" ] && pid=$(cat "$LOCK_FILE") && ps -p "$pid" > /dev/null 2>&1 && exit 1
echo $$ > "$LOCK_FILE"

while true; do
    clear
    MONITOR=$(mpvpaper -d | grep "Output:" | awk '{print $3}' | head -n 1)
    echo -e "\e[1;36mLucina Engine v3.2.1 | Codec: $CURRENT_CODEC | Monitor: $MONITOR\e[0m"
    OPTION=$(echo -e "▶️ Iniciar Wallpaper\n🔄 Restaurar Último\n⚙️  Cambiar Codec\n❌ Salir" | fzf --prompt="Acción: ")

    case "$OPTION" in
        "▶️ Iniciar Wallpaper")
            SELECTED=$(find "$BASE_DIR" -maxdepth 2 -type f \( -name "*.mp4" -o -name "*.mkv" -o -name "*.png" -o -name "*.jpg" -o -name "*.jpeg" -o -name "*.webp" -o -name "*.gif" \) | sort | fzf --prompt="Fondo: ")
            [ -z "$SELECTED" ] && continue
            MODE=$(echo "performance mid low very_low" | tr ' ' '\n' | fzf --prompt="Perfil: ")
            [ -z "$MODE" ] && continue
            start_engine "$SELECTED" "$MODE"
            ;;
        "🔄 Restaurar Último")
            [ -f "$STATE_FILE" ] && start_engine "$(cat "$STATE_FILE")" "$(cat "$PROFILE_FILE" 2>/dev/null || echo "very_low")"
            ;;
        "⚙️  Cambiar Codec")
            NEW_CODEC=$(echo -e "vaapi\nnvdec\nauto\nsoftware" | fzf --prompt="Codec: ")
            [ ! -z "$NEW_CODEC" ] && echo "$NEW_CODEC" > "$CODEC_FILE" && CURRENT_CODEC=$NEW_CODEC
            ;;
        *) exit 0 ;;
    esac
done
